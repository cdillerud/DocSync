  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Image Name="Logo">
            <Source>Database</Source><Value>=First(Fields!CompanyLogo.Value,"DataSet_Result")</Value><MIMEType>image/jpeg</MIMEType><Sizing>FitProportional</Sizing>
            <Top>0in</Top><Left>0in</Left><Height>0.7in</Height><Width>3.2in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Image>
          <Textbox Name="Title">
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>BLANKET</Value><Style><FontFamily>Arial</FontFamily><FontSize>13pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>SALES ORDER</Value><Style><FontFamily>Arial</FontFamily><FontSize>13pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph>
            </Paragraphs>
            <Top>0.18in</Top><Left>5.05in</Left><Height>0.55in</Height><Width>2.75in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="DocumentNo">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>="#" &amp; First(Fields!BlanketOrderNo.Value,"DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight><Color>#555555</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
            <Top>0.76in</Top><Left>5.05in</Left><Height>0.2in</Height><Width>2.75in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="CompanyLine">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!CompanyName.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyAddress.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!CompanyPostCode.Value,"DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Color>#444444</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>0.96in</Top><Left>0in</Left><Height>0.22in</Height><Width>5.4in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="BillTo">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>BILL TO</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>=First(Fields!BillToName.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!BillToAddress.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!BillToCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!BillToState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!BillToPostCode.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
            </Paragraphs>
            <Top>1.28in</Top><Left>0in</Left><Height>0.86in</Height><Width>3.75in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><BackgroundColor>#FAFAFA</BackgroundColor><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>8pt</PaddingLeft><PaddingTop>6pt</PaddingTop></Style>
          </Textbox>
          <Textbox Name="ShipTo">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>SHIP TO</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>=First(Fields!ShipToName.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!ShipToAddress.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!ShipToCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!ShipToState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!ShipToPostCode.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
            </Paragraphs>
            <Top>1.28in</Top><Left>4.05in</Left><Height>0.86in</Height><Width>3.75in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><BackgroundColor>#FAFAFA</BackgroundColor><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>8pt</PaddingLeft><PaddingTop>6pt</PaddingTop></Style>
          </Textbox>
          <Textbox Name="DetailsLeft">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>Contact: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!ContactName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Customer No.: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!CustomerNo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Salesperson: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!SalespersonName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Location: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!LocationCode.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
            </Paragraphs>
            <Top>2.34in</Top><Left>0in</Left><Height>0.95in</Height><Width>3.75in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Color>#8C1D18</Color><Style>Solid</Style><Width>0.8pt</Width></Border><PaddingLeft>9pt</PaddingLeft><PaddingTop>7pt</PaddingTop></Style>
          </Textbox>
          <Textbox Name="DetailsRight">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>Order Date: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=Format(First(Fields!OrderDate.Value,"DataSet_Result"),"MM/dd/yy")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Requested Delivery: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=IIF(Year(First(Fields!RequestedDeliveryDate.Value,"DataSet_Result"))=1,"",Format(First(Fields!RequestedDeliveryDate.Value,"DataSet_Result"),"MM/dd/yy"))</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Customer P.O.: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!CustomerPONo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Terms: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!PaymentTermsDescription.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
            </Paragraphs>
            <Top>2.34in</Top><Left>4.05in</Left><Height>0.95in</Height><Width>3.75in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Color>#8C1D18</Color><Style>Solid</Style><Width>0.8pt</Width></Border><PaddingLeft>9pt</PaddingLeft><PaddingTop>7pt</PaddingTop></Style>
          </Textbox>
          <Tablix Name="Lines">
            <TablixBody>
              <TablixColumns>
