          </Textbox>
          <Textbox Name="Contact">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!ContactLine.Value,"DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
            <Top>6.75in</Top><Left>0in</Left><Height>0.25in</Height><Width>7.8in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="Footer">
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>This blanket sales order is subject to the Standard Terms and Conditions for Customer Sales of Gamer Packaging, Inc.</Value><Style><FontStyle>Italic</FontStyle><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>https://www.gamerpackaging.com/terms-conditions-customer-sales/</Value><Style><Color>#8C1D18</Color><TextDecoration>Underline</TextDecoration></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>=First(Fields!CompanyName.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyAddress.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!CompanyPostCode.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyPhone.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyHomePage.Value,"DataSet_Result")</Value><Style><FontSize>7pt</FontSize><Color>#444444</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph>
            </Paragraphs>
