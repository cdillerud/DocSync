  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Image Name="CompanyLogoImage">
            <Source>Database</Source><Value>=First(Fields!CompanyLogo.Value,"DataSet_Result")</Value><MIMEType>image/jpeg</MIMEType><Sizing>FitProportional</Sizing>
            <Top>0in</Top><Left>0in</Left><Height>0.55in</Height><Width>2.7in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Image>
          <Textbox Name="DocumentTitle">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>CUSTOMER OPEN ORDER STATUS</Value><Style><FontFamily>Arial</FontFamily><FontSize>15pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
            <Top>0.12in</Top><Left>5.9in</Left><Height>0.35in</Height><Width>4.4in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="CompanyLine">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!CompanyName.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyAddressLine.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyPhone.Value,"DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Color>#444444</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>0.66in</Top><Left>0in</Left><Height>0.22in</Height><Width>10.3in</Width><Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="CustomerBox">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>CUSTOMER</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>=First(Fields!CustomerName.Value,"DataSet_Result") &amp; " (" &amp; First(Fields!CustomerNo.Value,"DataSet_Result") &amp; ")" &amp; vbCrLf &amp; First(Fields!CustomerAddressLine.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!CustomerContact.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
            </Paragraphs>
            <Top>1.02in</Top><Left>0in</Left><Height>0.8in</Height><Width>5.0in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>7pt</PaddingLeft><PaddingTop>5pt</PaddingTop><BackgroundColor>#FAFAFA</BackgroundColor></Style>
          </Textbox>
          <Textbox Name="StatusBox">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>Report Date: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=Format(First(Fields!ReportDate.Value,"DataSet_Result"),"MM/dd/yyyy")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Outside Sales: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!SalespersonName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Inside Sales: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!InsideSalespersonName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Expected dates are estimates and may change.</Value><Style><FontStyle>Italic</FontStyle></Style></TextRun></TextRuns></Paragraph>
            </Paragraphs>
            <Top>1.02in</Top><Left>5.2in</Left><Height>0.8in</Height><Width>5.1in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>7pt</PaddingLeft><PaddingTop>5pt</PaddingTop></Style>
          </Textbox>
          <Tablix Name="OpenOrderLines">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>0.75in</Width></TablixColumn>
