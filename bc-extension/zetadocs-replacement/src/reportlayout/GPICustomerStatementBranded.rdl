                    <TablixCell><CellContents><Textbox Name="DType"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!LineDocumentType.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><PaddingLeft>3pt</PaddingLeft><Border><Color>#DDDDDD</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="DDocument"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!LineDocumentNo.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><PaddingLeft>3pt</PaddingLeft><Border><Color>#DDDDDD</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="DDescription"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Fields!LineExternalDocumentNo.Value="",Fields!LineDescription.Value,Fields!LineDescription.Value &amp; " (" &amp; Fields!LineExternalDocumentNo.Value &amp; ")")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><PaddingLeft>3pt</PaddingLeft><Border><Color>#DDDDDD</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="DAmount"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!LineAmount.Value,"C2")</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><PaddingRight>3pt</PaddingRight><Border><Color>#DDDDDD</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="DRemaining"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!LineRemainingAmount.Value,"C2")</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><PaddingRight>3pt</PaddingRight><Border><Color>#DDDDDD</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="DBalance"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!LineRunningBalance.Value,"C2")</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><PaddingRight>3pt</PaddingRight><Border><Color>#DDDDDD</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
