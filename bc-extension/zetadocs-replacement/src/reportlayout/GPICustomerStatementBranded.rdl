  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Image Name="Logo">
            <Source>Database</Source><Value>=First(Fields!CompanyLogo.Value,"DataSet_Result")</Value><MIMEType>image/jpeg</MIMEType><Sizing>FitProportional</Sizing>
            <Top>0in</Top><Left>0in</Left><Height>0.65in</Height><Width>3.1in</Width><Style><Border><Style>None</Style></Border></Style>
          </Image>
          <Textbox Name="Title">
            <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>CUSTOMER STATEMENT</Value><Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
            <Top>0.18in</Top><Left>4.55in</Left><Height>0.35in</Height><Width>3.25in</Width><Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="CompanyLine">
            <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!CompanyName.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyAddress.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!CompanyPostCode.Value,"DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Color>#444444</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>0.82in</Top><Left>0in</Left><Height>0.22in</Height><Width>7.8in</Width><Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="CustomerBlock">
            <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>STATEMENT FOR</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>=First(Fields!CustomerName.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!CustomerAddress.Value,"DataSet_Result") &amp; IIF(First(Fields!CustomerAddress2.Value,"DataSet_Result")="","",vbCrLf &amp; First(Fields!CustomerAddress2.Value,"DataSet_Result")) &amp; vbCrLf &amp; First(Fields!CustomerCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CustomerState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!CustomerPostCode.Value,"DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.12in</Top><Left>0in</Left><Height>1.05in</Height><Width>3.8in</Width><Style><BackgroundColor>#FAFAFA</BackgroundColor><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>8pt</PaddingLeft><PaddingTop>6pt</PaddingTop></Style>
          </Textbox>
          <Textbox Name="PeriodBlock">
            <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Customer No.: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!CustomerNo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Statement Period: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=Format(First(Fields!StatementStartDate.Value,"DataSet_Result"),"MM/dd/yyyy") &amp; " through " &amp; Format(First(Fields!StatementEndDate.Value,"DataSet_Result"),"MM/dd/yyyy")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Currency: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!CurrencyCode.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.12in</Top><Left>4.0in</Left><Height>1.05in</Height><Width>3.8in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><Border><Color>#8C1D18</Color><Style>Solid</Style><Width>0.8pt</Width></Border><PaddingLeft>9pt</PaddingLeft><PaddingTop>7pt</PaddingTop></Style>
          </Textbox>
          <Textbox Name="SummaryBlock">
            <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Opening Balance: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=Format(First(Fields!OpeningBalance.Value,"DataSet_Result"),"C2")</Value></TextRun><TextRun><Value>     Ending Balance: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=Format(First(Fields!EndingBalance.Value,"DataSet_Result"),"C2")</Value></TextRun><TextRun><Value>     Current Outstanding: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=Format(First(Fields!OutstandingBalance.Value,"DataSet_Result"),"C2")</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>2.32in</Top><Left>0in</Left><Height>0.35in</Height><Width>7.8in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><BackgroundColor>#F2F2F2</BackgroundColor><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.5pt</Width></Border><PaddingLeft>6pt</PaddingLeft><PaddingTop>5pt</PaddingTop></Style>
          </Textbox>
