<Textbox Name="Vendor"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>BUY FROM</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>=First(Fields!VendorName.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!VendorAddress.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!VendorCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!VendorState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!VendorPostCode.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.28in</Top><Left>0in</Left><Height>0.86in</Height><Width>3.75in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><BackgroundColor>#FAFAFA</BackgroundColor><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>8pt</PaddingLeft><PaddingTop>6pt</PaddingTop></Style></Textbox>
<Textbox Name="ShipTo"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>SHIP TO</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>=First(Fields!ShipToName.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!ShipToAddress.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!ShipToCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!ShipToState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!ShipToPostCode.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.28in</Top><Left>4.05in</Left><Height>0.86in</Height><Width>3.75in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><BackgroundColor>#FAFAFA</BackgroundColor><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>8pt</PaddingLeft><PaddingTop>6pt</PaddingTop></Style></Textbox>
<Textbox Name="Details"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>Vendor Contact: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!VendorContact.Value,"DataSet_Result")</Value></TextRun><TextRun><Value>     Vendor No.: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!VendorNo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Order Date: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=Format(First(Fields!OrderDate.Value,"DataSet_Result"),"MM/dd/yy")</Value></TextRun><TextRun><Value>     Expected Receipt: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=IIF(Year(First(Fields!ExpectedReceiptDate.Value,"DataSet_Result"))=1,"",Format(First(Fields!ExpectedReceiptDate.Value,"DataSet_Result"),"MM/dd/yy"))</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Purchaser: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!PurchaserName.Value,"DataSet_Result")</Value></TextRun><TextRun><Value>     Terms: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!PaymentTermsDescription.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>2.34in</Top><Left>0in</Left><Height>0.82in</Height><Width>7.8in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Color>#8C1D18</Color><Style>Solid</Style><Width>0.8pt</Width></Border><PaddingLeft>9pt</PaddingLeft><PaddingTop>7pt</PaddingTop></Style></Textbox>
