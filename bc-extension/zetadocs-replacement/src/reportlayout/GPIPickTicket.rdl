  <ReportSections><ReportSection><Body><ReportItems>
    <Image Name="Logo"><Source>Database</Source><Value>=First(Fields!CompanyLogo.Value,"DataSet_Result")</Value><MIMEType>image/jpeg</MIMEType><Sizing>FitProportional</Sizing><Top>0in</Top><Left>0in</Left><Height>0.72in</Height><Width>3.25in</Width><Style><Border><Style>None</Style></Border></Style></Image>
    <Textbox Name="Title"><Paragraphs><Paragraph><TextRuns><TextRun><Value>WAREHOUSE PICK INSTRUCTION</Value><Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><Color>#A6A6A6</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Top>0.12in</Top><Left>3.25in</Left><Height>0.38in</Height><Width>4.55in</Width><Style><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="Tagline"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Experts in complete packaging solutions.</Value><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><FontStyle>Italic</FontStyle></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>0.78in</Top><Left>0.1in</Left><Height>0.2in</Height><Width>3.5in</Width><Style><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="Warehouse"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>Warehouse: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=First(Fields!WarehouseDisplayName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Ship Date: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=IIF(Year(First(Fields!ShipDate.Value,"DataSet_Result"))=1,"",Format(First(Fields!ShipDate.Value,"DataSet_Result"),"MM/dd/yy"))</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.35in</Top><Left>0in</Left><Height>0.8in</Height><Width>2.3in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="ShipTo"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>Ship To: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=First(Fields!ShipToName.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!ShipToAddress.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!ShipToCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!ShipToState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!ShipToPostCode.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.35in</Top><Left>2.35in</Left><Height>0.8in</Height><Width>2.7in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="OrderInfo"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>Order Number: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=First(Fields!OrderNo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Order Date: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=Format(First(Fields!OrderDate.Value,"DataSet_Result"),"MM/dd/yy")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Salesperson: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=First(Fields!SalespersonName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Inside Salesperson: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=First(Fields!InsideSalespersonName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.35in</Top><Left>5.25in</Left><Height>0.8in</Height><Width>2.55in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="SummaryBar"><Paragraphs><Paragraph><TextRuns><TextRun><Value>="Customer No.             " &amp; First(Fields!CustomerNo.Value,"DataSet_Result") &amp; "                 Customer P.O.             " &amp; First(Fields!CustomerPONo.Value,"DataSet_Result") &amp; "                 Shipping Agent             " &amp; First(Fields!ShippingAgentDescription.Value,"DataSet_Result")</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Top>2.35in</Top><Left>0in</Left><Height>0.34in</Height><Width>7.8in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><BackgroundColor>#D9D9D9</BackgroundColor><Border><Style>None</Style></Border><PaddingTop>5pt</PaddingTop></Style></Textbox>
    <Tablix Name="LinesTable"><TablixBody><TablixColumns><TablixColumn><Width>1.25in</Width></TablixColumn><TablixColumn><Width>3.55in</Width></TablixColumn><TablixColumn><Width>0.75in</Width></TablixColumn><TablixColumn><Width>1.2in</Width></TablixColumn><TablixColumn><Width>1.05in</Width></TablixColumn></TablixColumns><TablixRows>
      <TablixRow><Height>0.32in</Height><TablixCells>
        <TablixCell><CellContents><Textbox Name="H1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Item Code</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#D9D9D9</BackgroundColor></Style></Textbox></CellContents></TablixCell>
        <TablixCell><CellContents><Textbox Name="H2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Description</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#D9D9D9</BackgroundColor></Style></Textbox></CellContents></TablixCell>
        <TablixCell><CellContents><Textbox Name="H3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Whse</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#D9D9D9</BackgroundColor></Style></Textbox></CellContents></TablixCell>
        <TablixCell><CellContents><Textbox Name="H4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Amt. Ordered</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#D9D9D9</BackgroundColor><TextAlign>Right</TextAlign></Style></Textbox></CellContents></TablixCell>
        <TablixCell><CellContents><Textbox Name="H5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>U/M</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#D9D9D9</BackgroundColor></Style></Textbox></CellContents></TablixCell>
      </TablixCells></TablixRow>
      <TablixRow><Height>0.3in</Height><TablixCells>
        <TablixCell><CellContents><Textbox Name="D1"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ItemNo.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
        <TablixCell><CellContents><Textbox Name="D2"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!LineDescription.Value &amp; IIF(Fields!LineDescription2.Value="","",vbCrLf &amp; Fields!LineDescription2.Value)</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
        <TablixCell><CellContents><Textbox Name="D3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Fields!LineLocationCode.Value)</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
        <TablixCell><CellContents><Textbox Name="D4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Format(Fields!Quantity.Value,"0.###"))</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><TextAlign>Right</TextAlign></Style></Textbox></CellContents></TablixCell>
        <TablixCell><CellContents><Textbox Name="D5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Fields!UnitOfMeasureCode.Value)</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
      </TablixCells></TablixRow>
    </TablixRows></TablixBody><TablixColumnHierarchy><TablixMembers><TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/></TablixMembers></TablixColumnHierarchy><TablixRowHierarchy><TablixMembers><TablixMember><KeepWithGroup>After</KeepWithGroup><RepeatOnNewPage>true</RepeatOnNewPage></TablixMember><TablixMember><Group Name="DetailsGroup"/></TablixMember></TablixMembers></TablixRowHierarchy><DataSetName>DataSet_Result</DataSetName><Top>2.85in</Top><Left>0in</Left><Height>0.62in</Height><Width>7.8in</Width><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize></Style></Tablix>
    <Textbox Name="Contact"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!ContactLine.Value,"DataSet_Result")</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Top>7.0in</Top><Left>0in</Left><Height>0.25in</Height><Width>7.8in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="FIFO"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Please ensure inventory is pulled according to FIFO methods.</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>7.35in</Top><Left>0in</Left><Height>0.25in</Height><Width>7.8in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="Footer"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>This offer is subject to the Standard Terms and Conditions of Gamer Packaging, Inc. which is set forth on our website.</Value><Style><FontStyle>Italic</FontStyle><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>https://www.gamerpackaging.com/terms-conditions/</Value><Style><Color>#0563C1</Color><TextDecoration>Underline</TextDecoration></Style></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>=First(Fields!CompanyName.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyAddress.Value,"DataSet_Result") &amp; IIF(First(Fields!CompanyAddress2.Value,"DataSet_Result")="",""," " &amp; First(Fields!CompanyAddress2.Value,"DataSet_Result")) &amp; ", " &amp; First(Fields!CompanyCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!CompanyPostCode.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyPhone.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyHomePage.Value,"DataSet_Result")</Value><Style><FontSize>7pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Top>7.72in</Top><Left>0in</Left><Height>0.65in</Height><Width>7.8in</Width><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
  </ReportItems><Height>8.5in</Height><Style /></Body><Width>7.8in</Width><Page><PageHeader><Height>0.2in</Height><PrintOnFirstPage>true</PrintOnFirstPage><PrintOnLastPage>true</PrintOnLastPage><ReportItems><Textbox Name="PageCount"><Paragraphs><Paragraph><TextRuns><TextRun><Value>="Page " &amp; Globals!PageNumber &amp; " of " &amp; Globals!TotalPages</Value><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Top>0in</Top><Left>6.65in</Left><Height>0.2in</Height><Width>1.15in</Width><Style><Border><Style>None</Style></Border></Style></Textbox></ReportItems><Style /></PageHeader><PageHeight>11in</PageHeight><PageWidth>8.5in</PageWidth><LeftMargin>0.35in</LeftMargin><RightMargin>0.35in</RightMargin><TopMargin>0.3in</TopMargin><BottomMargin>0.3in</BottomMargin><Style /></Page></ReportSection></ReportSections>
  <rd:ReportUnitType>Inch</rd:ReportUnitType><rd:ReportID>33333333-3333-3333-3333-333333333333</rd:ReportID>
