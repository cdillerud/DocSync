    <Field Name="CompanyState"><DataField>CompanyState</DataField><rd:TypeName>System.String</rd:TypeName></Field>
    <Field Name="CompanyPostCode"><DataField>CompanyPostCode</DataField><rd:TypeName>System.String</rd:TypeName></Field>
