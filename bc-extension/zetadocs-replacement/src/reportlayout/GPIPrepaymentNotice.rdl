                  <TablixCell><CellContents><Textbox Name="D2"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!LineDescription.Value &amp; IIF(Fields!LineDescription2.Value="","",vbCrLf &amp; Fields!LineDescription2.Value)</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Border><Style>None</Style></Border><PaddingTop>3pt</PaddingTop><PaddingBottom>3pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Fields!LineLocationCode.Value)</Value></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Border><Style>None</Style></Border><PaddingTop>3pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Fields!UnitOfMeasureCode.Value)</Value></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Border><Style>None</Style></Border><PaddingTop>3pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Format(Fields!Quantity.Value,"0.###"))</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Border><Style>None</Style></Border><PaddingTop>3pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Format(Fields!UnitPrice.Value,"N2"))</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Border><Style>None</Style></Border><PaddingTop>3pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Format(Fields!LineAmount.Value,"N2"))</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Border><Style>None</Style></Border><PaddingTop>3pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.22in</Height><TablixCells>
                  <TablixCell><CellContents ColSpan="5"><Textbox Name="SubtotalBlank"><Paragraphs><Paragraph><TextRuns><TextRun><Value /></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="SubtotalLabel"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Subtotal</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border><PaddingTop>2pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="SubtotalValue"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(First(Fields!SubtotalAmount.Value,"DataSet_Result"),"N2")</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border><PaddingTop>2pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.22in</Height><TablixCells>
                  <TablixCell><CellContents ColSpan="5"><Textbox Name="TaxBlank"><Paragraphs><Paragraph><TextRuns><TextRun><Value /></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="TaxLabel"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Sales Tax</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border><PaddingTop>2pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="TaxValue"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(First(Fields!TaxAmount.Value,"DataSet_Result"),"N2")</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border><PaddingTop>2pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.24in</Height><TablixCells>
                  <TablixCell><CellContents ColSpan="5"><Textbox Name="TotalBlank"><Paragraphs><Paragraph><TextRuns><TextRun><Value /></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="TotalLabel"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Order Total</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>Solid</Style><Color>#808080</Color><Width>0.5pt</Width></Border><PaddingTop>2pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="TotalValue"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(First(Fields!OrderTotalAmount.Value,"DataSet_Result"),"N2")</Value></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>Solid</Style><Color>#808080</Color><Width>0.5pt</Width></Border><PaddingTop>2pt</PaddingTop></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.18in</Height><TablixCells><TablixCell><CellContents ColSpan="7"><Textbox Name="Spacer1"><Paragraphs><Paragraph><TextRuns><TextRun><Value /></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>None</Style></Border></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow>
                <TablixRow><Height>0.32in</Height><TablixCells><TablixCell><CellContents ColSpan="7"><Textbox Name="PrepaymentRequired"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(First(Fields!PrepaymentPercent.Value,"DataSet_Result"),"0.##") &amp; "% Prepayment Required"</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>None</Style></Border><PaddingTop>4pt</PaddingTop></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow>
                <TablixRow><Height>0.36in</Height><TablixCells><TablixCell><CellContents ColSpan="7"><Textbox Name="AmountDue"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Prepayment Amount Due   </Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>="$" &amp; Format(First(Fields!PrepaymentAmountDue.Value,"DataSet_Result"),"N2")</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>None</Style></Border><PaddingTop>5pt</PaddingTop></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow>
                <TablixRow><Height>0.38in</Height><TablixCells><TablixCell><CellContents ColSpan="7"><Textbox Name="ShipmentNote"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>Upon shipment, a final invoice will be sent. Deduct the amount prepaid from the invoice total.</Value><Style><Color>Red</Color><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><Border><Style>None</Style></Border><PaddingTop>8pt</PaddingTop></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow>
                <TablixRow><Height>0.9in</Height><TablixCells><TablixCell><CellContents ColSpan="7"><Textbox Name="PaymentInstructions"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>Gamer Packaging is pleased to offer several payment options.</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph><Paragraph><TextRuns><TextRun><Value>Please visit the payments page on our website for more information:</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph><Paragraph><TextRuns><TextRun><Value>https://www.gamerpackaging.com/payment-instructions/</Value><Style><Color>#0563C1</Color><TextDecoration>Underline</TextDecoration><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph><Paragraph><TextRuns><TextRun><Value>* Payments made by credit card are subject to an administrative surcharge.</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><Border><Style>None</Style></Border><PaddingTop>5pt</PaddingTop></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow>
                <TablixRow><Height>0.42in</Height><TablixCells><TablixCell><CellContents ColSpan="7"><Textbox Name="Contact"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!ContactLine.Value,"DataSet_Result")</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><Border><Style>None</Style></Border><PaddingTop>10pt</PaddingTop></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow>
                <TablixRow><Height>0.85in</Height><TablixCells><TablixCell><CellContents ColSpan="7"><Textbox Name="TermsFooter"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>This offer is subject to the Standard Terms and Conditions of Gamer Packaging, Inc. which is set forth on our website:</Value><Style><FontStyle>Italic</FontStyle><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph><Paragraph><TextRuns><TextRun><Value>https://www.gamerpackaging.com/terms-conditions-customer-sales/</Value><Style><Color>#0563C1</Color><TextDecoration>Underline</TextDecoration></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph><Paragraph><TextRuns><TextRun><Value>=First(Fields!CompanyName.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyAddress.Value,"DataSet_Result") &amp; IIF(First(Fields!CompanyAddress2.Value,"DataSet_Result")="",""," " &amp; First(Fields!CompanyAddress2.Value,"DataSet_Result")) &amp; ", " &amp; First(Fields!CompanyCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!CompanyPostCode.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyPhone.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyHomePage.Value,"DataSet_Result")</Value><Style><FontSize>7pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Border><Style>None</Style></Border><PaddingTop>7pt</PaddingTop></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow>
              </TablixRows>
