  <ReportSections><ReportSection><Body><ReportItems>
    <Image Name="Logo"><Source>Database</Source><Value>=First(Fields!CompanyLogo.Value,"DataSet_Result")</Value><MIMEType>image/jpeg</MIMEType><Sizing>FitProportional</Sizing><Top>0in</Top><Left>0in</Left><Height>0.58in</Height><Width>2.55in</Width><Style><Border><Style>None</Style></Border></Style></Image>
    <Textbox Name="Tagline"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Experts in complete packaging solutions.</Value><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><FontStyle>Italic</FontStyle></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>0.64in</Top><Left>0.08in</Left><Height>0.18in</Height><Width>3.0in</Width><Style><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="Title"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Prepayment Notice</Value><Style><FontFamily>Arial</FontFamily><FontSize>17pt</FontSize><Color>#8C8C8C</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Top>0.06in</Top><Left>4.35in</Left><Height>0.34in</Height><Width>3.45in</Width><Style><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="OrderInfo"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Order Number: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=First(Fields!OrderNo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Order Date: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=Format(First(Fields!OrderDate.Value,"DataSet_Result"),"MM/dd/yy")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>0.72in</Top><Left>4.55in</Left><Height>0.45in</Height><Width>3.25in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="BillToLabel"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Bill To</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.25in</Top><Left>0in</Left><Height>0.22in</Height><Width>0.65in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="BillToAddress"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!BillToName.Value,"DataSet_Result") &amp; IIF(First(Fields!BillToName2.Value,"DataSet_Result")="","",vbCrLf &amp; First(Fields!BillToName2.Value,"DataSet_Result")) &amp; vbCrLf &amp; First(Fields!BillToAddress.Value,"DataSet_Result") &amp; IIF(First(Fields!BillToAddress2.Value,"DataSet_Result")="","",vbCrLf &amp; First(Fields!BillToAddress2.Value,"DataSet_Result")) &amp; vbCrLf &amp; First(Fields!BillToCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!BillToState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!BillToPostCode.Value,"DataSet_Result") &amp; IIF(First(Fields!BillToCountry.Value,"DataSet_Result")="" Or UCase(First(Fields!BillToCountry.Value,"DataSet_Result"))="US" Or UCase(First(Fields!BillToCountry.Value,"DataSet_Result"))="USA","",vbCrLf &amp; First(Fields!BillToCountry.Value,"DataSet_Result"))</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.25in</Top><Left>0.72in</Left><Height>0.84in</Height><Width>1.82in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="ShipToLabel"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Ship To</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.25in</Top><Left>2.6in</Left><Height>0.22in</Height><Width>0.65in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="ShipToAddress"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!ShipToName.Value,"DataSet_Result") &amp; IIF(First(Fields!ShipToName2.Value,"DataSet_Result")="","",vbCrLf &amp; First(Fields!ShipToName2.Value,"DataSet_Result")) &amp; vbCrLf &amp; First(Fields!ShipToAddress.Value,"DataSet_Result") &amp; IIF(First(Fields!ShipToAddress2.Value,"DataSet_Result")="","",vbCrLf &amp; First(Fields!ShipToAddress2.Value,"DataSet_Result")) &amp; vbCrLf &amp; First(Fields!ShipToCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!ShipToState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!ShipToPostCode.Value,"DataSet_Result") &amp; IIF(First(Fields!ShipToCountry.Value,"DataSet_Result")="" Or UCase(First(Fields!ShipToCountry.Value,"DataSet_Result"))="US" Or UCase(First(Fields!ShipToCountry.Value,"DataSet_Result"))="USA","",vbCrLf &amp; First(Fields!ShipToCountry.Value,"DataSet_Result"))</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.25in</Top><Left>3.22in</Left><Height>0.84in</Height><Width>1.83in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="RepInfo"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Requested Receive by Date: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=IIF(Year(First(Fields!RequestedReceiveByDate.Value,"DataSet_Result"))=1,"",Format(First(Fields!RequestedReceiveByDate.Value,"DataSet_Result"),"MM/dd/yy"))</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Salesperson: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=First(Fields!SalespersonName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Inside Salesperson: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=First(Fields!InsideSalespersonName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.25in</Top><Left>5.15in</Left><Height>0.84in</Height><Width>2.65in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
    <Textbox Name="ConfirmTo"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Confirm To: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=First(Fields!ConfirmTo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>2.18in</Top><Left>0in</Left><Height>0.22in</Height><Width>3.2in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
