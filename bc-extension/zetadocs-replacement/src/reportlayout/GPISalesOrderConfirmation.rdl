          </Tablix>
          <Textbox Name="TotalsBox">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>="Subtotal: " &amp; Format(First(Fields!SubtotalAmount.Value, "DataSet_Result"), "N2") &amp; vbCrLf &amp; "Sales Tax: " &amp; Format(First(Fields!TaxAmount.Value, "DataSet_Result"), "N2") &amp; vbCrLf &amp; "Order Total: " &amp; First(Fields!CurrencyCode.Value, "DataSet_Result") &amp; " " &amp; Format(First(Fields!OrderTotalAmount.Value, "DataSet_Result"), "N2")</Value><Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
            <Top>5.2in</Top><Left>5.1in</Left><Height>0.75in</Height><Width>2.7in</Width>
            <Style><Border><Color>#1F4E79</Color><Style>Solid</Style><Width>1pt</Width></Border><PaddingTop>4pt</PaddingTop><PaddingRight>4pt</PaddingRight></Style>
          </Textbox>
          <Textbox Name="TermsBox">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>NOTE: Upon receipt and inspection of your order, please note any damage or discrepancy on the carrier's copy of the bill of lading.</Value><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>This offer is subject to the Standard Terms and Conditions for Customer Sales of Gamer Packaging, Inc. available at www.gamerpackaging.com/terms-conditions-customer-sales/.</Value><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>6.15in</Top><Left>0in</Left><Height>0.65in</Height><Width>7.8in</Width>
