  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="TitleBox">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>SALES ORDER CONFIRMATION</Value><Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>#1F4E79</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
            <Top>0in</Top><Left>3.8in</Left><Height>0.35in</Height><Width>4in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="CompanyBox">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!CompanyName.Value, "DataSet_Result") &amp; vbCrLf &amp; First(Fields!CompanyAddress.Value, "DataSet_Result") &amp; vbCrLf &amp; First(Fields!CompanyCity.Value, "DataSet_Result") &amp; ", " &amp; First(Fields!CompanyState.Value, "DataSet_Result") &amp; " " &amp; First(Fields!CompanyPostCode.Value, "DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>0in</Top><Left>0in</Left><Height>0.7in</Height><Width>3.5in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="BillToBox">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>="BILL TO" &amp; vbCrLf &amp; First(Fields!BillToName.Value, "DataSet_Result") &amp; vbCrLf &amp; First(Fields!BillToAddress.Value, "DataSet_Result") &amp; vbCrLf &amp; First(Fields!BillToCity.Value, "DataSet_Result") &amp; ", " &amp; First(Fields!BillToState.Value, "DataSet_Result") &amp; " " &amp; First(Fields!BillToPostCode.Value, "DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>0.85in</Top><Left>0in</Left><Height>0.9in</Height><Width>3.7in</Width>
            <Style><Border><Color>#B4C6E7</Color><Style>Solid</Style><Width>0.75pt</Width></Border><PaddingLeft>6pt</PaddingLeft><PaddingTop>5pt</PaddingTop><BackgroundColor>#F8FAFD</BackgroundColor></Style>
          </Textbox>
          <Textbox Name="ShipToBox">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>="SHIP TO" &amp; vbCrLf &amp; First(Fields!ShipToName.Value, "DataSet_Result") &amp; vbCrLf &amp; First(Fields!ShipToAddress.Value, "DataSet_Result") &amp; vbCrLf &amp; First(Fields!ShipToCity.Value, "DataSet_Result") &amp; ", " &amp; First(Fields!ShipToState.Value, "DataSet_Result") &amp; " " &amp; First(Fields!ShipToPostCode.Value, "DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>0.85in</Top><Left>4.1in</Left><Height>0.9in</Height><Width>3.7in</Width>
            <Style><Border><Color>#B4C6E7</Color><Style>Solid</Style><Width>0.75pt</Width></Border><PaddingLeft>6pt</PaddingLeft><PaddingTop>5pt</PaddingTop><BackgroundColor>#F8FAFD</BackgroundColor></Style>
          </Textbox>
          <Textbox Name="OrderDetailsBox">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>="Confirm To: " &amp; First(Fields!ConfirmTo.Value, "DataSet_Result") &amp; vbCrLf &amp; "Order Number: " &amp; First(Fields!OrderNo.Value, "DataSet_Result") &amp; "    Order Date: " &amp; Format(First(Fields!OrderDate.Value, "DataSet_Result"), "MM/dd/yy") &amp; vbCrLf &amp; "Salesperson: " &amp; First(Fields!SalespersonName.Value, "DataSet_Result") &amp; "    Inside Salesperson: " &amp; First(Fields!InsideSalespersonName.Value, "DataSet_Result") &amp; vbCrLf &amp; "Customer No.: " &amp; First(Fields!CustomerNo.Value, "DataSet_Result") &amp; "    Customer P.O.: " &amp; First(Fields!CustomerPONo.Value, "DataSet_Result") &amp; vbCrLf &amp; "Shipping Method: " &amp; First(Fields!ShipmentMethodDescription.Value, "DataSet_Result") &amp; "    Terms: " &amp; First(Fields!PaymentTermsDescription.Value, "DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.9in</Top><Left>0in</Left><Height>0.8in</Height><Width>7.8in</Width>
            <Style><Border><Color>#B4C6E7</Color><Style>Solid</Style><Width>0.75pt</Width></Border><PaddingLeft>5pt</PaddingLeft><PaddingTop>4pt</PaddingTop></Style>
          </Textbox>
