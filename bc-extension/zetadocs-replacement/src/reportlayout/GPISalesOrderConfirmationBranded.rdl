        <Field Name="UnitPrice"><DataField>UnitPrice</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="LineAmount"><DataField>LineAmount</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Image Name="Logo">
            <Source>Database</Source><Value>=First(Fields!CompanyLogo.Value,"DataSet_Result")</Value><MIMEType>image/jpeg</MIMEType><Sizing>FitProportional</Sizing>
            <Top>0in</Top><Left>0in</Left><Height>0.72in</Height><Width>3.25in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Image>
          <Textbox Name="Tagline">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Experts in complete packaging solutions.</Value><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><FontStyle>Italic</FontStyle><Color>#555555</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>0.82in</Top><Left>0.1in</Left><Height>0.2in</Height><Width>3.25in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="CompanyAddressBox">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!CompanyName.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyAddress.Value,"DataSet_Result") &amp; IIF(First(Fields!CompanyAddress2.Value,"DataSet_Result")="", "", " " &amp; First(Fields!CompanyAddress2.Value,"DataSet_Result")) &amp; ", " &amp; First(Fields!CompanyCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!CompanyPostCode.Value,"DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Color>#444444</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.05in</Top><Left>0.1in</Left><Height>0.25in</Height><Width>4.4in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="TitleBox">
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>SALES ORDER</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>CONFIRMATION</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph>
            </Paragraphs>
            <Top>0.25in</Top><Left>5.2in</Left><Height>0.48in</Height><Width>2.6in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="BillToBox">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>BILL TO</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>=First(Fields!BillToName.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!BillToAddress.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!BillToCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!BillToState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!BillToPostCode.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
            </Paragraphs>
            <Top>1.38in</Top><Left>0in</Left><Height>0.88in</Height><Width>3.75in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>8pt</PaddingLeft><PaddingTop>6pt</PaddingTop><BackgroundColor>#FAFAFA</BackgroundColor></Style>
          </Textbox>
          <Textbox Name="ShipToBox">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>SHIP TO</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>=First(Fields!ShipToName.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!ShipToAddress.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!ShipToCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!ShipToState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!ShipToPostCode.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
            </Paragraphs>
            <Top>1.38in</Top><Left>4.05in</Left><Height>0.88in</Height><Width>3.75in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>8pt</PaddingLeft><PaddingTop>6pt</PaddingTop><BackgroundColor>#FAFAFA</BackgroundColor></Style>
          </Textbox>
          <Textbox Name="DetailsLeft">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>Confirm To: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!ConfirmTo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Salesperson: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!SalespersonName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Customer No.: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!CustomerNo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Shipping Method: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!ShipmentMethodDescription.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>FOB: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!FOBText.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
            </Paragraphs>
            <Top>2.45in</Top><Left>0in</Left><Height>1.18in</Height><Width>3.55in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Color>#8C1D18</Color><Style>Solid</Style><Width>0.8pt</Width></Border><PaddingLeft>9pt</PaddingLeft><PaddingTop>7pt</PaddingTop></Style>
          </Textbox>
          <Textbox Name="DetailsRight">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>Order Number: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!OrderNo.Value,"DataSet_Result")</Value></TextRun><TextRun><Value>    Order Date: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=Format(First(Fields!OrderDate.Value,"DataSet_Result"),"MM/dd/yy")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Requested Receive by Date: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=IIF(Year(First(Fields!RequestedDeliveryDate.Value,"DataSet_Result"))=1,"",Format(First(Fields!RequestedDeliveryDate.Value,"DataSet_Result"),"MM/dd/yy"))</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Inside Salesperson: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!InsideSalespersonName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Customer P.O.: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!CustomerPONo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>Terms: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!PaymentTermsDescription.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph>
            </Paragraphs>
            <Top>2.45in</Top><Left>3.55in</Left><Height>1.18in</Height><Width>4.25in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Color>#8C1D18</Color><Style>Solid</Style><Width>0.8pt</Width></Border><PaddingLeft>9pt</PaddingLeft><PaddingTop>7pt</PaddingTop></Style>
          </Textbox>
          <Tablix Name="LinesTable">
            <TablixBody>
              <TablixColumns><TablixColumn><Width>0.9in</Width></TablixColumn><TablixColumn><Width>3.15in</Width></TablixColumn><TablixColumn><Width>0.55in</Width></TablixColumn><TablixColumn><Width>0.55in</Width></TablixColumn><TablixColumn><Width>0.75in</Width></TablixColumn><TablixColumn><Width>0.85in</Width></TablixColumn><TablixColumn><Width>1.05in</Width></TablixColumn></TablixColumns>
              <TablixRows>
                <TablixRow><Height>0.32in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="H1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Item Code</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#8C1D18</BackgroundColor><PaddingLeft>3pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="H2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Description</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#8C1D18</BackgroundColor><PaddingLeft>3pt</PaddingLeft></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="H3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Whse</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#8C1D18</BackgroundColor><TextAlign>Center</TextAlign></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="H4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>U/M</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#8C1D18</BackgroundColor><TextAlign>Center</TextAlign></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="H5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Amt. Ordered</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#8C1D18</BackgroundColor><TextAlign>Right</TextAlign><PaddingRight>3pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="H6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Price (USD$)</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#8C1D18</BackgroundColor><TextAlign>Right</TextAlign><PaddingRight>3pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="H7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Line Total</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>#8C1D18</BackgroundColor><TextAlign>Right</TextAlign><PaddingRight>3pt</PaddingRight></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
                <TablixRow><Height>0.31in</Height><TablixCells>
                  <TablixCell><CellContents><Textbox Name="D1"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ItemNo.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><PaddingLeft>3pt</PaddingLeft><Border><Color>#D7D7D7</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D2"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!LineDescription.Value &amp; IIF(Fields!LineDescription2.Value="","",vbCrLf &amp; Fields!LineDescription2.Value)</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><PaddingLeft>3pt</PaddingLeft><Border><Color>#D7D7D7</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Fields!LineLocationCode.Value)</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><TextAlign>Center</TextAlign><Border><Color>#D7D7D7</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Fields!UnitOfMeasureCode.Value)</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><TextAlign>Center</TextAlign><Border><Color>#D7D7D7</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Format(Fields!Quantity.Value,"0.##"))</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><TextAlign>Right</TextAlign><PaddingRight>3pt</PaddingRight><Border><Color>#D7D7D7</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Format(Fields!UnitPrice.Value,"N2"))</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><TextAlign>Right</TextAlign><PaddingRight>3pt</PaddingRight><Border><Color>#D7D7D7</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                  <TablixCell><CellContents><Textbox Name="D7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(Trim(CStr(Fields!ItemNo.Value))="",Nothing,Format(Fields!LineAmount.Value,"N2"))</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><TextAlign>Right</TextAlign><PaddingRight>3pt</PaddingRight><Border><Color>#D7D7D7</Color><Style>Solid</Style><Width>0.25pt</Width></Border></Style></Textbox></CellContents></TablixCell>
                </TablixCells></TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy><TablixMembers><TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/></TablixMembers></TablixColumnHierarchy>
            <TablixRowHierarchy><TablixMembers><TablixMember><KeepWithGroup>After</KeepWithGroup><RepeatOnNewPage>true</RepeatOnNewPage></TablixMember><TablixMember><Group Name="DetailsGroup"/></TablixMember></TablixMembers></TablixRowHierarchy>
            <DataSetName>DataSet_Result</DataSetName>
            <Top>3.8in</Top><Left>0in</Left><Height>0.63in</Height><Width>7.8in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize></Style>
          </Tablix>
          <Textbox Name="TotalsBox">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>="Subtotal:      " &amp; Format(First(Fields!SubtotalAmount.Value,"DataSet_Result"),"N2")</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>="Sales Tax:      " &amp; Format(First(Fields!TaxAmount.Value,"DataSet_Result"),"N2")</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>="Order Total (" &amp; First(Fields!CurrencyCode.Value,"DataSet_Result") &amp; "):      " &amp; Format(First(Fields!OrderTotalAmount.Value,"DataSet_Result"),"N2")</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph>
            </Paragraphs>
            <Top>5.05in</Top><Left>5.05in</Left><Height>0.82in</Height><Width>2.75in</Width>
            <Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><Border><Color>#8C1D18</Color><Style>Solid</Style><Width>0.8pt</Width></Border><PaddingTop>6pt</PaddingTop><PaddingRight>7pt</PaddingRight></Style>
          </Textbox>
          <Textbox Name="ContactLineBox">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!ContactLine.Value,"DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
            <Top>6.75in</Top><Left>0in</Left><Height>0.25in</Height><Width>7.8in</Width>
            <Style><Border><Style>None</Style></Border></Style>
          </Textbox>
          <Textbox Name="FooterBox">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph><TextRuns><TextRun><Value>NOTE: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>Upon receipt and inspection of your order, please note any damage or discrepancy on the carrier's copy of the bill of lading.</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph>
              <Paragraph><TextRuns><TextRun><Value>This offer is subject to the Standard Terms and Conditions for Customer Sales of Gamer Packaging, Inc. which is set forth on our website.</Value><Style><FontStyle>Italic</FontStyle><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph>
