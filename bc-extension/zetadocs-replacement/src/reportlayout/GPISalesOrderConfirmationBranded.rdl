<Textbox Name="Footer"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>NOTE: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>Upon receipt and inspection of your order, please note any damage or discrepancy on the carrier's copy of the bill of lading.</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>This offer is subject to the Standard Terms and Conditions for Customer Sales of Gamer Packaging, Inc. available at www.gamerpackaging.com/terms-conditions-customer-sales/.</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>8.2in</Top><Left>0in</Left><Height>0.65in</Height><Width>7.8in</Width><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Border><Style>None</Style></Border></Style></Textbox>
