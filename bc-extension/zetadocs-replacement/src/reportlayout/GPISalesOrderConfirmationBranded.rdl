<Textbox Name="Addr"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!CompanyName.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!CompanyAddress.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!CompanyCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!CompanyPostCode.Value,"DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>0.76in</Top><Left>0.18in</Left><Height>0.5in</Height><Width>3.15in</Width><Style><Border><Style>None</Style></Border></Style></Textbox>
<Textbox Name="Title"><Paragraphs><Paragraph><TextRuns><TextRun><Value>SALES ORDER</Value><Style><FontFamily>Arial</FontFamily><FontSize>13pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph><Paragraph><TextRuns><TextRun><Value>CONFIRMATION</Value><Style><FontFamily>Arial</FontFamily><FontSize>13pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Top>0.18in</Top><Left>5.05in</Left><Height>0.5in</Height><Width>2.75in</Width><Style><Border><Style>None</Style></Border></Style></Textbox>
