  <DataSets>
    <DataSet Name="DataSet_Result">
      <Query><DataSourceName>DataSource</DataSourceName><CommandText /></Query>
      <Fields>
        <Field Name="CompanyLogo"><DataField>CompanyLogo</DataField><rd:TypeName>System.Byte[]</rd:TypeName></Field>
        <Field Name="CompanyName"><DataField>CompanyName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="CompanyAddress"><DataField>CompanyAddress</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="CompanyAddress2"><DataField>CompanyAddress2</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="CompanyCity"><DataField>CompanyCity</DataField><rd:TypeName>System.String</rd:TypeName></Field>
