        <Field Name="BillToPostCode"><DataField>BillToPostCode</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ShipToName"><DataField>ShipToName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ShipToAddress"><DataField>ShipToAddress</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ShipToCity"><DataField>ShipToCity</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ShipToState"><DataField>ShipToState</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ShipToPostCode"><DataField>ShipToPostCode</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ConfirmTo"><DataField>ConfirmTo</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="OrderNo"><DataField>OrderNo</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="OrderDate"><DataField>OrderDate</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="RequestedDeliveryDate"><DataField>RequestedDeliveryDate</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="CustomerNo"><DataField>CustomerNo</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="CustomerPONo"><DataField>CustomerPONo</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ShipmentMethodDescription"><DataField>ShipmentMethodDescription</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="FOBText"><DataField>FOBText</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="PaymentTermsDescription"><DataField>PaymentTermsDescription</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="SalespersonName"><DataField>SalespersonName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="InsideSalespersonName"><DataField>InsideSalespersonName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="BackupInsideSalespersonName"><DataField>BackupInsideSalespersonName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ContactLine"><DataField>ContactLine</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="CurrencyCode"><DataField>CurrencyCode</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="SubtotalAmount"><DataField>SubtotalAmount</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="TaxAmount"><DataField>TaxAmount</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="OrderTotalAmount"><DataField>OrderTotalAmount</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="ItemNo"><DataField>ItemNo</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="LineDescription"><DataField>LineDescription</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="LineDescription2"><DataField>LineDescription2</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="LineLocationCode"><DataField>LineLocationCode</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="UnitOfMeasureCode"><DataField>UnitOfMeasureCode</DataField><rd:TypeName>System.String</rd:TypeName></Field>
