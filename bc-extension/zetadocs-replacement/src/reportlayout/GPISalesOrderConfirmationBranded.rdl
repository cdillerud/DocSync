        <Field Name="CompanyHomePage"><DataField>CompanyHomePage</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="BillToName"><DataField>BillToName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="BillToAddress"><DataField>BillToAddress</DataField><rd:TypeName>System.String</rd:TypeName></Field>
