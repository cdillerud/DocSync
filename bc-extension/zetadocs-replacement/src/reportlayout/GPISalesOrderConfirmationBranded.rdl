<Textbox Name="Details"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>="Confirm To: " &amp; First(Fields!ConfirmTo.Value,"DataSet_Result") &amp; "        Order Number: " &amp; First(Fields!OrderNo.Value,"DataSet_Result") &amp; "        Order Date: " &amp; Format(First(Fields!OrderDate.Value,"DataSet_Result"),"MM/dd/yy")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>="Salesperson: " &amp; First(Fields!SalespersonName.Value,"DataSet_Result") &amp; "        Inside Salesperson: " &amp; First(Fields!InsideSalespersonName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>="Customer No.: " &amp; First(Fields!CustomerNo.Value,"DataSet_Result") &amp; "        Customer P.O.: " &amp; First(Fields!CustomerPONo.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>="Shipping Method: " &amp; First(Fields!ShipmentMethodDescription.Value,"DataSet_Result") &amp; "        Terms: " &amp; First(Fields!PaymentTermsDescription.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>2.48in</Top><Left>0in</Left><Height>1in</Height><Width>7.8in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Color>#8C1D18</Color><Style>Solid</Style><Width>0.8pt</Width></Border><PaddingLeft>8pt</PaddingLeft><PaddingTop>6pt</PaddingTop></Style></Textbox>
