<Textbox Name="Company"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!CompanyName.Value,"DataSet_Result") &amp; " | " &amp; First(Fields!CompanyAddress.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyCity.Value,"DataSet_Result") &amp; ", " &amp; First(Fields!CompanyState.Value,"DataSet_Result") &amp; " " &amp; First(Fields!CompanyPostCode.Value,"DataSet_Result")</Value><Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize><Color>#444444</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>0.96in</Top><Left>0in</Left><Height>0.22in</Height><Width>5.5in</Width><Style><Border><Style>None</Style></Border></Style></Textbox>
<Textbox Name="Warehouse"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>RECEIVING LOCATION</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>=First(Fields!LocationName.Value,"DataSet_Result") &amp; " (" &amp; First(Fields!LocationCode.Value,"DataSet_Result") &amp; ")" &amp; vbCrLf &amp; First(Fields!LocationAddress.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!LocationCityStateZip.Value,"DataSet_Result") &amp; vbCrLf &amp; First(Fields!LocationContact.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.28in</Top><Left>0in</Left><Height>1.02in</Height><Width>3.75in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><BackgroundColor>#FAFAFA</BackgroundColor><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>8pt</PaddingLeft><PaddingTop>6pt</PaddingTop></Style></Textbox>
<Textbox Name="Vendor"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>SUPPLIER</Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>=First(Fields!VendorName.Value,"DataSet_Result") &amp; " (" &amp; First(Fields!VendorNo.Value,"DataSet_Result") &amp; ")" &amp; vbCrLf &amp; First(Fields!VendorContact.Value,"DataSet_Result") &amp; vbCrLf &amp; "Shipment Method: " &amp; First(Fields!ShipmentMethodDescription.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>1.28in</Top><Left>4.05in</Left><Height>1.02in</Height><Width>3.75in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8.5pt</FontSize><BackgroundColor>#FAFAFA</BackgroundColor><Border><Color>#C8C8C8</Color><Style>Solid</Style><Width>0.6pt</Width></Border><PaddingLeft>8pt</PaddingLeft><PaddingTop>6pt</PaddingTop></Style></Textbox>
<Textbox Name="ReceiptDate"><Paragraphs><Paragraph><TextRuns><TextRun><Value>WAREHOUSE RECEIPT DATE</Value><Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph><Paragraph><TextRuns><TextRun><Value>=Format(First(Fields!WarehouseReceiptDate.Value,"DataSet_Result"),"MM/dd/yyyy")</Value><Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>#333333</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Top>2.5in</Top><Left>0in</Left><Height>0.72in</Height><Width>3.75in</Width><Style><Border><Color>#8C1D18</Color><Style>Solid</Style><Width>1pt</Width></Border><PaddingTop>5pt</PaddingTop></Style></Textbox>
<Textbox Name="Details"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Order Date: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=Format(First(Fields!OrderDate.Value,"DataSet_Result"),"MM/dd/yy")</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Expected Receipt: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=IIF(Year(First(Fields!ExpectedReceiptDate.Value,"DataSet_Result"))=1,"",Format(First(Fields!ExpectedReceiptDate.Value,"DataSet_Result"),"MM/dd/yy"))</Value></TextRun></TextRuns></Paragraph><Paragraph><TextRuns><TextRun><Value>Purchaser: </Value><Style><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun><TextRun><Value>=First(Fields!PurchaserName.Value,"DataSet_Result")</Value></TextRun></TextRuns></Paragraph></Paragraphs><Top>2.5in</Top><Left>4.05in</Left><Height>0.72in</Height><Width>3.75in</Width><Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Border><Color>#8C1D18</Color><Style>Solid</Style><Width>0.8pt</Width></Border><PaddingLeft>9pt</PaddingLeft><PaddingTop>7pt</PaddingTop></Style></Textbox>
