<Textbox Name="Title"><Paragraphs><Paragraph><TextRuns><TextRun><Value>WAREHOUSE</Value><Style><FontFamily>Arial</FontFamily><FontSize>13pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph><Paragraph><TextRuns><TextRun><Value>RECEIVING NOTICE</Value><Style><FontFamily>Arial</FontFamily><FontSize>13pt</FontSize><FontWeight>Bold</FontWeight><Color>#8C1D18</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Top>0.18in</Top><Left>4.65in</Left><Height>0.55in</Height><Width>3.15in</Width><Style><Border><Style>None</Style></Border></Style></Textbox>
